{
  "name": "llama-dash-docs",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "version": "0.0.1",
  "description": "Marketing and docs project for llama-dash",
  "license": "MIT",
  "author": "ndom91 <info@llama-dash.dev>",
  "homepage": "https://llama-dash.dev/",
  "bugs": "https://github.com/ndom91/llama-dash-doc/issues",
  "repository": "https://github.com/ndom91/llama-dash-docs",
  "keywords": [
    "llama-dash",
    "fumadocs",
    "documentation",
    "marketing"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "NITRO_PRESET=node-server vite build",
    "start": "serve .output/public --config ../../serve.json",
    "preview": "vite preview",
    "preview:cf": "pnpm build && wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "types:check": "fumadocs-mdx && tsgo --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format:fix": "biome format --write"
  },
  "dependencies": {
    "@orama/orama": "3.1.18",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/start-static-server-functions": "1.167.17",
    "fumadocs-core": "16.10.5",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-ui": "16.10.5",
    "lucide-react": "1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "vite": "8.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@tailwindcss/vite": "4.3.1",
    "@types/mdx": "2.0.14",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "nitro": "3.0.260610-beta",
    "serve": "14.2.6",
    "srvx": "0.11.17",
    "tailwindcss": "4.3.1",
    "@typescript/native-preview": "7.0.0-dev.20260624.1",
    "vite-plugin-svgr": "5.2.0",
    "wrangler": "4.104.0"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
